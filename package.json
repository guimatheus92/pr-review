{
  "name": "pr-review",
  "version": "0.1.5",
  "description": "Generic, plugin-based PR review for GitHub and Azure DevOps. Orchestrates parallel reviewer agents in a single agent session (Copilot CLI or Claude Code) with stack/business-rule skills.",
  "private": true,
  "type": "module",
  "bin": {
    "pr-review": "./bin/pr-review"
  },
  "scripts": {
    "build": "tsc && npm run bundle",
    "build:watch": "tsc --watch",
    "bundle": "node scripts/bundle.mjs",
    "test": "node scripts/test.mjs",
    "clean": "rimraf dist",
    "prepare": "npm run build"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@octokit/rest": "^21.0.2",
    "azure-devops-node-api": "^15.1.2",
    "commander": "^12.1.0",
    "p-limit": "^6.2.0",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "esbuild": "^0.24.2",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
